# Network
HTTP_PORT=80
# Порт на хосте для фронта (docker compose up → http://localhost:3000/)
FRONTEND_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=portfolio
DATABASE_URL=postgresql+asyncpg://portfolio:change_me_strong_password@db:5432/portfolio

# Media
UPLOAD_DIR=/app/data/uploads
LEGACY_MEDIA_BIND=./legacy_media
LEGACY_MEDIA_IMPORT_DIR=/legacy_media
STATIC_SEED_IMAGES_DIR=/theme_static/images
THEME_STATIC_BIND=./theme/static/images
FORCE_LEGACY_MEDIA_REIMPORT=false

# Adminer (всегда в docker compose up; БД: сервер db, пользователь/БД из POSTGRES_*)
# Локально: http://127.0.0.1:8080 — с другой машины: SSH-туннель ssh -L 8080:127.0.0.1:8080 user@сервер
# Открыть в интернет без Traefik: ADMINER_HOST=0.0.0.0 (риск: защитите файрволом/VPN)
ADMINER_HOST=127.0.0.1
ADMINER_PORT=8080
# Фото: Adminer правит только таблицы. Файлы кладите в том API (uploads), в collection_items.image_path — относительный путь к файлу в /media (например myphoto.jpg).
# С Traefik: поддомен в DNS + пароль для входа в Adminer (не путать с паролем PostgreSQL)
TRAEFIK_ADMINER_HOST=adminer.example.com
# Сгенерировать: docker run --rm httpd:2.4-alpine htpasswd -nb admin ВашПароль
# В .env каждый $ в хэше удваивайте (например apr1$$...)
# ADMINER_BASIC_AUTH_USERS=admin:$$apr1$$...

# Email / feedback
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
FEEDBACK_FROM_EMAIL=
FEEDBACK_TO_EMAIL=

# Traefik / TLS
TRAEFIK_DOMAIN=example.com
ACME_EMAIL=admin@example.com
