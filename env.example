# Порт Nginx на хосте
HTTP_PORT=3000

# База данных
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=portfolio
DATABASE_URL=postgresql+asyncpg://portfolio:change_me_strong_password@db:5432/portfolio

# CORS (через запятую)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Пути для импорта медиа
UPLOAD_DIR=/app/data/uploads
LEGACY_MEDIA_IMPORT_DIR=/legacy_media
STATIC_SEED_IMAGES_DIR=/theme_static/images
FORCE_LEGACY_MEDIA_REIMPORT=false
LEGACY_MEDIA_BIND=./legacy_media
THEME_STATIC_BIND=./theme/static/images

# SMTP (форма обратной связи)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
FEEDBACK_FROM_EMAIL=
FEEDBACK_TO_EMAIL=

# Дополнительные сервисы
ADMINER_PORT=8080

# Traefik + TLS
TRAEFIK_DOMAIN=example.com
ACME_EMAIL=admin@example.com
